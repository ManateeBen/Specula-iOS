# Copy this file to .env.local before building a TestFlight archive.
# Do not commit .env.local.
#
# These values are bundled into the web assets at build time. They are hidden
# from normal UI, but they are not cryptographically secret inside a shipped IPA.
# Use a backend proxy before public release.

VITE_SPECULA_TEXT_API_KEY=replace-with-testflight-text-key
VITE_SPECULA_VISION_API_KEY=replace-with-testflight-vision-key
VITE_ENABLE_QUICK_BROWSE=true
